#include "$AC_HOME/acc-runtime/stdlib/grid/funcs.h"
#include "$AC_HOME/acc-runtime/stdlib/math"
#include "$AC_HOME/acc-runtime/stdlib/general_derivs.h"
#include "$AC_HOME/acc-runtime/stdlib/general_operators.h"
#include "$AC_HOME/acc-runtime/stdlib/poisson.h"
#include "$AC_HOME/acc-runtime/stdlib/bc.h"
#include "$AC_HOME/acc-runtime/stdlib/cg.h"
Field HEAT_INIT
Field HEAT_SOLUTION
Field HEAT_SOLUTION_4TH_ORDER
Field SOLUTION_DIFF
Field HEAT_RHS
Field HEAT_RHS_4TH_ORDER
Field ANALYTICAL_SOLUTION
real AC_k = 1.0
global output real AC_rhs2
Kernel init_kernel()
{
	pos = grid_position()
	rhs = sin(AC_k*pos.x)*sin(AC_k*pos.y)*sin(AC_k*pos.z)
	write(HEAT_INIT,rhs)
	write(ANALYTICAL_SOLUTION,-(1.0/3.0)*rhs)
	write(HEAT_SOLUTION,0.0)
	write(HEAT_SOLUTION_4TH_ORDER,0.0)
}

Field DIFF_RHS
Field ANALYTICAL_RHS
Field DIFF_DEL2
Field DIFF_DEL4
Field DIFF_D2X2Y
Field DIFF_ANALYTICAL_ORDERS 
bool AC_use_analytical_rhs = false
Kernel init_2nd_kernel()
{
	
        h2 = AC_ds_2.x
        h4 = AC_ds_4.x
        analytical_res = HEAT_INIT + (h2/12.0)*(-3*HEAT_INIT)
#if STENCIL_ORDER == 6
	       + (h4/360.0)*(9*HEAT_INIT)
               + (h4/180.0)*(3*HEAT_INIT)
#endif
        analytical_res_4th_order = HEAT_INIT + (h2/12.0)*(-3*HEAT_INIT)

	write(DIFF_ANALYTICAL_ORDERS,analytical_res-analytical_res_4th_order)
	numerical_res = compact_poisson_rhs(HEAT_INIT)
	if(AC_use_analytical_rhs)
	{
		write(HEAT_RHS,analytical_res)
	}
	else
	{
		write(HEAT_RHS,numerical_res)
	}
	write(ANALYTICAL_RHS,analytical_res)
	write(HEAT_RHS_4TH_ORDER,analytical_res_4th_order)
	reduce_sum(analytical_res*analytical_res,AC_rhs2)
}
Kernel init_3rd_kernel()
{
	r = HEAT_RHS -(compact_poisson_lhs(HEAT_SOLUTION))
	write(CG_P,r)
	write(CG_R,r)

	r = HEAT_RHS_4TH_ORDER -(compact_poisson_lhs_4th_order(HEAT_SOLUTION_4TH_ORDER))
	write(CG_P_4TH_ORDER,r)
	write(CG_R_4TH_ORDER,r)
}

ac_rhs_bc(AcBoundary boundary)
{
	const int3 normal = get_normal(boundary)
	const int3 boundary_point = get_boundary(normal)
	int3 ghost  = boundary_point
	for i in 0:NGHOST
	{
		ghost  = ghost  + normal
		pos = grid_position(ghost)
		rhs = sin(AC_k*pos.x)*sin(AC_k*pos.y)*sin(AC_k*pos.z)
		if(ghost == (int3){0,0,NGHOST})
		{
			print("Updating init at (0,0,NGHOST): %.14e\n",rhs)
		}	
		HEAT_INIT[ghost.x][ghost.y][ghost.z] = rhs
	}
}

ac_analytical_solution_bc(AcBoundary boundary)
{
	const int3 normal = get_normal(boundary)
	const int3 boundary_point = get_boundary(normal)
	int3 ghost  = boundary_point
	for i in 0:NGHOST
	{
		ghost  = ghost  + normal
		pos = grid_position(ghost)
 		res = -(1.0/3.0)*sin(AC_k*pos.x)*sin(AC_k*pos.y)*sin(AC_k*pos.z)
		if(ghost == (int3){0,0,0})
		{
			print("Updating solution at (0,0,0): %.14e\n",res)
			print("Position is (0,0,0): %.14e,%.14e,%.14e\n"
					,pos.x
					,pos.y
					,pos.z
				)
		}	
		HEAT_SOLUTION[ghost.x][ghost.y][ghost.z] = res
		HEAT_SOLUTION_4TH_ORDER[ghost.x][ghost.y][ghost.z] = res
	}
}

Field CG_P
Field CG_R
Field CG_P_4TH_ORDER
Field CG_R_4TH_ORDER

BoundConds boundconds{
   ac_rhs_bc(BOUNDARY_XYZ)
   ac_analytical_solution_bc(BOUNDARY_XYZ)
   ac_const_bc(BOUNDARY_XYZ,CG_P,0.0)
   ac_const_bc(BOUNDARY_XYZ,CG_R,0.0)
   ac_const_bc(BOUNDARY_XYZ,CG_P_4TH_ORDER,0.0)
   ac_const_bc(BOUNDARY_XYZ,CG_R_4TH_ORDER,0.0)
}


ComputeSteps
initcond(boundconds)
{
	init_kernel()
	init_2nd_kernel()
	init_3rd_kernel()
}
ComputeSteps
empty_steps(boundconds)
{
}

fixed_boundary Kernel jacobi_kernel()
{
	Mx = compact_poisson_lhs_neighbours(HEAT_SOLUTION)
	a  = compact_poisson_lhs_central_coeff()
	f  = HEAT_RHS
	write(HEAT_SOLUTION,(f-Mx)/a)
}

ComputeSteps jacobi_step(boundconds)
{
	jacobi_kernel()
}


Kernel cg_compute_alpha()
{
	Ap = compact_poisson_lhs(CG_P)
 	r  = value(CG_R)
	p  = value(CG_P)
	cg_compute_inner_products(Ap,p,r)
}

Kernel cg_advance()
{
	Ap = compact_poisson_lhs(CG_P)
	p  = value(CG_P)
	cg_advance_solution(HEAT_SOLUTION,Ap,p,CG_R)
}

Kernel cg_advance_p()
{
	cg_next_direction(CG_P,CG_R)
}

ComputeSteps
cg_step(boundconds)
{
	cg_compute_alpha()
	cg_advance()
	cg_advance_p()
}

Kernel cg_compute_alpha_4th_order()
{
	Ap = compact_poisson_lhs_4th_order(CG_P_4TH_ORDER)
 	r  = value(CG_R_4TH_ORDER)
	p  = value(CG_P_4TH_ORDER)
	cg_compute_inner_products(Ap,p,r)
}

Kernel cg_advance_4th_order()
{
	Ap = compact_poisson_lhs_4th_order(CG_P_4TH_ORDER)
	p  = value(CG_P_4TH_ORDER)
	cg_advance_solution(HEAT_SOLUTION_4TH_ORDER,Ap,p,CG_R_4TH_ORDER)
}

Kernel cg_advance_p_4th_order()
{
	cg_next_direction(CG_P_4TH_ORDER,CG_R_4TH_ORDER)
}


ComputeSteps
cg_4th_order_step(boundconds)
{
	cg_compute_alpha_4th_order()
	cg_advance_4th_order()
	cg_advance_p_4th_order()
}



output real AC_residual2
Kernel residual_kernel()
{
	Ax = compact_poisson_lhs(HEAT_SOLUTION)
	r = HEAT_RHS-Ax
	reduce_sum(r*r,AC_residual2)
}

ComputeSteps
get_residual(boundconds)
{
	residual_kernel()
}

Field DIFF
global output real AC_l2_from_analytical_solution
global output real AC_4th_order_l2_from_analytical_solution
Kernel get_diff_to_analytical_solution_kernel()
{
	diff = ANALYTICAL_SOLUTION-HEAT_SOLUTION
	diff_4th_order = ANALYTICAL_SOLUTION-HEAT_SOLUTION_4TH_ORDER
	write(DIFF,diff)
	reduce_sum(diff*diff,AC_l2_from_analytical_solution)
	reduce_sum(diff_4th_order*diff_4th_order,AC_4th_order_l2_from_analytical_solution)
	write(SOLUTION_DIFF,HEAT_SOLUTION-HEAT_SOLUTION_4TH_ORDER)
}

ComputeSteps
get_diff_to_analytical_solution(boundconds)
{
	get_diff_to_analytical_solution_kernel()
}

