hostdefine STENCIL_ORDER (6)

#include "$AC_HOME/acc-runtime/stdlib/grid/funcs.h"
#include "$AC_HOME/acc-runtime/stdlib/math"
#include "$AC_HOME/acc-runtime/stdlib/general_derivs.h"
#include "$AC_HOME/acc-runtime/stdlib/general_operators.h"
#include "$AC_HOME/acc-runtime/stdlib/poisson.h"
#include "$AC_HOME/acc-runtime/stdlib/bc.h"
#include "$AC_HOME/acc-runtime/stdlib/cg.h"
Field HEAT_INIT
Field HEAT_SOLUTION
real AC_k = 1.0
Field TEST_SOLUTION
Field TEST_HEAT

Field RESIDUAL

Field CG_P 
Field CG_R

input real AC_laplace_sign

Kernel init_kernel(real init_sign)
{
	//Not using the sine wave example since due to being eigensolution would converge in a single step
	pos = grid_position()
	write(HEAT_INIT,init_sign*(pos.x + pos.y + pos.z))
	write(HEAT_SOLUTION,0.0)
	write(TEST_SOLUTION, (1.0/6.0)*(pos.x*pos.x*pos.x + pos.y*pos.y*pos.y + pos.z*pos.z*pos.z))
}
bc_heat(AcBoundary boundary, Field f) {
   const int3 normal = get_normal(boundary)
   const int3 boundary_point = get_boundary(normal)
   int3 ghost  = boundary_point
   for i in 0:NGHOST
   {
           ghost  = ghost  + normal
	   pos = grid_position(ghost)
           f[ghost.x][ghost.y][ghost.z] = (1.0/6.0)*((pos.x*pos.x*pos.x) + (pos.y*pos.y*pos.y) + (pos.z*pos.z*pos.z));
   }

}

bc_heat_source(AcBoundary boundary, Field f)
{
   const int3 normal = get_normal(boundary)
   const int3 boundary_point = get_boundary(normal)
   int3 ghost  = boundary_point
   for i in 0:NGHOST
   {
           ghost  = ghost  + normal
	   pos = grid_position(ghost)
           f[ghost.x][ghost.y][ghost.z] = pos.x + pos.y + pos.z;
   }

}

bc_schwarz(AcBoundary boundary, Field f)
{
	if(local_boundary_is_a_global_boundary(boundary))
	{
		bc_heat(boundary,f)
	}
	else
	{
		ac_fixed_bc(boundary,f)
	}
}


BoundConds boundconds{
	bc_heat(BOUNDARY_XYZ,HEAT_SOLUTION)
	ac_const_bc(BOUNDARY_XYZ,CG_P,0.0)
	bc_heat(BOUNDARY_XYZ,TEST_SOLUTION)
}

BoundConds schwarz_bcs {
	bc_schwarz(BOUNDARY_XYZ,HEAT_SOLUTION)
	ac_const_bc(BOUNDARY_XYZ,CG_P,0.0)
}

global output real AC_residual_l2_norm
output real AC_residual_local_l2_norm
Kernel global_residual_kernel(real laplace_sign)
{
	r = HEAT_INIT-(laplace_sign*laplace(HEAT_SOLUTION))
	write(RESIDUAL,r)
	reduce_l2_norm(r,AC_residual_l2_norm)
	write(TEST_HEAT,(-laplace_sign*laplace(TEST_SOLUTION)))
}

Kernel local_residual_kernel(real laplace_sign)
{
	r = HEAT_INIT-(laplace_sign*laplace(HEAT_SOLUTION))
	write(RESIDUAL,r)
	reduce_l2_norm(r,AC_residual_local_l2_norm)
}

ComputeSteps
initcond(boundconds)
{
	init_kernel(AC_laplace_sign)
}


ComputeSteps
empty_steps(boundconds)
{
}

Kernel
init_cg_solution()
{
	write(HEAT_SOLUTION,0.0)
}

Kernel
init_cg_residual()
{
	r = HEAT_INIT -(-laplace(HEAT_SOLUTION))
	write(CG_P,-r/laplace_central_coeff())
	write(CG_R,r)
}

Field CG_Z

Kernel 
cg_get_z(real laplace_sign)
{
	write(CG_Z,r/(laplace_sign*laplace_central_coeff()))
}


Kernel cg_compute_alpha(real laplace_sign)
{
	Ap = laplace_sign*laplace(CG_P)
 	r  = value(CG_R)
	p  = value(CG_P)
	z  = value(CG_Z)
	cg_compute_inner_products(Ap,p,r,z)
}


Kernel cg_advance(real laplace_sign)
{
	Ap = laplace_sign*laplace(CG_P)
	p  = value(CG_P)
	cg_advance_solution(HEAT_SOLUTION,Ap,p,CG_R)
}
Kernel cg_compute_beta()
{
	cg_compute_p1Tzp1(CG_R,CG_Z)
}


Kernel cg_advance_p()
{
	cg_next_direction(CG_P,-CG_R/laplace_central_coeff())
}

ComputeSteps
init_cg(boundconds)
{
	//init_cg_solution()
	init_cg_residual()
}

ComputeSteps
cg_step(boundconds)
{
	cg_get_z(AC_laplace_sign)

	cg_compute_alpha(AC_laplace_sign)
	cg_advance(AC_laplace_sign)

	cg_get_z(AC_laplace_sign)
	cg_compute_beta()
	cg_advance_p()
}

fixed_boundary Kernel sor_red(real laplace_sign, real omega)
{
	poisson_sor_red_black_extended(SOR_RED,value(HEAT_INIT),HEAT_SOLUTION,omega,laplace_sign)
}
fixed_boundary Kernel sor_black(real laplace_sign, real omega)
{
	poisson_sor_red_black_extended(SOR_BLACK,value(HEAT_INIT),HEAT_SOLUTION,omega,laplace_sign)
}

ComputeSteps
sor_red_black_step(boundconds)
{
	sor_red(AC_laplace_sign,1.0)
	sor_black(AC_laplace_sign,1.0)
}

Kernel cg_compute_alpha_local(real laplace_sign)
{
	Ap = laplace_sign*laplace(CG_P)
 	r  = value(CG_R)
	p  = value(CG_P)
	z = -r/laplace_central_coeff()
	cg_compute_inner_products_local(Ap,p,r,z)
}


Kernel cg_advance_local(real laplace_sign)
{
	Ap = laplace_sign*laplace(CG_P)
	p  = value(CG_P)
	cg_advance_solution_local(HEAT_SOLUTION,Ap,p,CG_R)
}
Kernel cg_compute_beta_local()
{
	z = -CG_R/laplace_central_coeff()	
	cg_compute_p1Tzp1_local(CG_R,z)
}


Kernel cg_advance_p_local()
{
	cg_next_direction_local(CG_P,-CG_R/laplace_central_coeff())
}

ComputeSteps
cg_local_step(schwarz_bcs)
{
	cg_compute_alpha_local(AC_laplace_sign)
	cg_advance_local(AC_laplace_sign)
	cg_compute_beta_local()
	cg_advance_p_local()
}

ComputeSteps
get_residual(boundconds)
{
	global_residual_kernel(AC_laplace_sign)
}

ComputeSteps
get_local_residual(schwarz_bcs)
{
	local_residual_kernel(AC_laplace_sign)
}

