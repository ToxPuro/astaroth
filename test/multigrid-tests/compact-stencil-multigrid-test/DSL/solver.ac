Kernel gmg_optimized_prototype_smoother_kernel(GMG_LEVEL level)
{
	Field u = GMG_SOLUTIONS[level]
	Field b = GMG_RHS[level]
	write(u,u + optimized_smoother(b,level) - dummy_r2_stencil(u))
}

Kernel gmg_optimized_prototype_smoother_kernel_v2(GMG_LEVEL level)
{
	Field u = GMG_SOLUTIONS[level]
	Field b = GMG_RHS[level]
	write(u,b-gmg_laplace(u,level) - dummy_r2_stencil(b) + dummy_r3_stencil(u))
}

