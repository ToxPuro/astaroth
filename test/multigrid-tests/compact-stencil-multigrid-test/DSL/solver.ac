hostdefine STENCIL_ORDER (6)

#include "$AC_HOME/acc-runtime/stdlib/grid/funcs.h"
#include "$AC_HOME/acc-runtime/stdlib/math"
#include "$AC_HOME/acc-runtime/stdlib/general_derivs.h"
#include "$AC_HOME/acc-runtime/stdlib/general_operators.h"
#include "$AC_HOME/acc-runtime/stdlib/poisson.h"
#include "$AC_HOME/acc-runtime/stdlib/bc.h"
#include "$AC_HOME/acc-runtime/stdlib/geometric_multigrid.h"

real AC_k = 1.0
real AC_laplace_sign = -1.0

Field TMP
real AC_init_val = 0.0
Kernel init_kernel()
{
	pos = grid_position()
	val = sin(AC_k*pos.x)*sin(AC_k*pos.y)*sin(AC_k*pos.z)
	write(TMP,val)
	write(GMG_SOLUTIONS[0],AC_init_val)
}
Kernel init_2nd_kernel()
{
	if(AC_compact_poisson)
	{
		write(GMG_INITIAL_RHS,compact_poisson_rhs(TMP))
	}
	else
	{
		write(GMG_INITIAL_RHS,TMP)
	}
}


