	return E_p*E_ptilde
}
**/

Kernel
calc_integral_trapezoidal()
{
	local_res = 0.0
	weight = AC_ds.x*AC_ds.y*AC_ds.z*AC_ds_w
	for w in 0:AC_nlocal_w
	{
		local_weight = weight
		if(globalVertexIdx.x == 0 || globalVertexIdx.x == AC_ngrid.x-1)
		{
			local_weight *= 0.5
		}
		if(globalVertexIdx.y == 0 || globalVertexIdx.y == AC_ngrid.y-1)
		{
			local_weight *= 0.5
		}
		
		if(AC_ngrid.z > 1 && (globalVertexIdx.z == 0 || globalVertexIdx.z == AC_ngrid.z-1))
		{
			local_weight *= 0.5
		}
		if(AC_nlocal_w > 1 && (w == 0 || w == AC_nlocal_w-1))
		{
		  local_weight *= 0.5
		}
		//local_res += local_weight*DATA[vertexIdx.x][vertexIdx.y][vertexIdx.z][w]
		local_res += local_weight*integrand_wrapper(w*AC_ds_w +AC_first_gridpoint_w)
	}
	reduce_sum(local_res,AC_integral_res)
}
Kernel
calc_integral_gauss_legendre()
{
	local_res = 0.0
	for w in 0:AC_nlocal_w
	{
		weight = X_W[vertexIdx.x]*Y_W[vertexIdx.y]*Z_W[vertexIdx.z]*W_W[w]	
		local_res += weight*integrand_wrapper(X[vertexIdx.x],Y[vertexIdx.y],Z[vertexIdx.z],W[w])
	}
	reduce_sum(local_res,AC_gauss_legendre_res)
}

BoundConds
bcs
{
	periodic(BOUNDARY_XYZ)
}

ComputeSteps
calc_integral_gauss(bcs)
{
	calc_integral_gauss_legendre()
}
ComputeSteps
calc_integral_trap(bcs)
{
	calc_integral_trapezoidal()
}
