{
    "version": 4,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 23
    },
    "configurePresets": [
        {
            "name": "puhti-mhd",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "OPTIMIZE_MEM_ACCESSES": "ON",
                "MPI_ENABLED": "ON",
                "SINGLEPASS_INTEGRATION": "OFF",
                "BUILD_STANDALONE": "ON",
                "BUILD_MHD_SAMPLES": "ON",
                "BUILD_SAMPLES": "ON",
                "MAX_THREADS_PER_BLOCK": "0"
            }
        },
        {
            "name": "mahti-mhd",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "OPTIMIZE_MEM_ACCESSES": "ON",
                "MPI_ENABLED": "ON",
                "SINGLEPASS_INTEGRATION": "OFF",
                "BUILD_STANDALONE": "ON",
                "BUILD_MHD_SAMPLES": "ON",
                "BUILD_SAMPLES": "ON",
                "MAX_THREADS_PER_BLOCK": "0"
            }
        },
        {
            "name": "lumi-mhd",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "OPTIMIZE_MEM_ACCESSES": "ON",
                "MPI_ENABLED": "ON",
                "SINGLEPASS_INTEGRATION": "OFF",
                "BUILD_STANDALONE": "ON",
                "BUILD_MHD_SAMPLES": "ON",
                "BUILD_SAMPLES": "ON",
                "MAX_THREADS_PER_BLOCK": "512"
            }
        },
        {
            "name": "lumi-tfm",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "OPTIMIZE_MEM_ACCESSES": "ON",
                "MPI_ENABLED": "ON",
                "SINGLEPASS_INTEGRATION": "ON",
                "BUILD_STANDALONE": "OFF",
                "BUILD_MHD_SAMPLES": "OFF",
                "BUILD_SAMPLES": "OFF",
                "DSL_MODULE_DIR": "${sourceDir}/samples/tfm/mhd",
                "PROGRAM_MODULE_DIR": "${sourceDir}/samples/tfm-mpi",
                "BUILD_ACC_RUNTIME_LIBRARY": "ON",
                "MAX_THREADS_PER_BLOCK": "512"
            }
        },
        {
            "name": "mahti-tfm",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "OPTIMIZE_MEM_ACCESSES": "ON",
                "MPI_ENABLED": "ON",
                "SINGLEPASS_INTEGRATION": "ON",
                "BUILD_STANDALONE": "OFF",
                "BUILD_MHD_SAMPLES": "OFF",
                "BUILD_SAMPLES": "OFF",
                "DSL_MODULE_DIR": "${sourceDir}/samples/tfm/mhd",
                "PROGRAM_MODULE_DIR": "${sourceDir}/samples/tfm-mpi",
                "BUILD_ACC_RUNTIME_LIBRARY": "ON"
            }
        }
    ]
}